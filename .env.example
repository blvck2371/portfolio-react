# Firebase — compteur de visiteurs en temps réel
# Copie ce fichier en .env et remplis avec ta config Firebase (Console Firebase > Paramètres du projet).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# EmailJS — formulaire de contact (voir CONTACT-EMAIL.md)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
# Template d'auto-réponse envoyé au visiteur (optionnel, laisser vide pour désactiver)
VITE_EMAILJS_TEMPLATE_ID_AUTO_REPLY=
VITE_EMAILJS_ACCESS_TOKEN=
