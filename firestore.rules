rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Compteur de visiteurs (portfolio 3D)
    match /stats/visitors {
      allow read, write: if true;
    }
    // Données du portfolio : lecture publique, écriture réservée aux utilisateurs connectés
    match /portfolio_projects/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /portfolio_experience/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /portfolio_tech/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /portfolio_certifications/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Config (présentation, etc.) : lecture publique, écriture admin
    match /portfolio_config/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Cartes services (sous Présentation) : lecture publique, écriture admin
    match /portfolio_services/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // CV : lien du PDF, lecture publique, écriture admin
    match /cv/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
